# [Application]
API_HTTP_GLOBAL_PREFIX=api
API_HTTP_PORT=3000
NODE_ENV=development

# [JWT Authentication]
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_EXPIRATION=1h

# [Database]
API_DATABASE_URL=postgresql://truck-database-user:truck-database-password@localhost:5432/truck-database

# [SMTP / Mail]
API_SMTP_HOST=localhost
API_SMTP_PORT=1025
API_SMTP_FROM="Truck System <noreply@truck-system.com>"

# [OpenAPI / Swagger]
API_OPENAPI_TITLE=Truck API
API_OPENAPI_DESCRIPTION=Truck API description
API_OPENAPI_VERSION=1.0.0

# [Keycloak / OIDC — JWT Validation]
KEYCLOAK_BASE_URL=http://localhost:8280
KEYCLOAK_REALM=truck
KEYCLOAK_JWKS_URI=http://localhost:8280/realms/truck/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://localhost:8280/realms/truck
KEYCLOAK_AUDIENCE=truck-api

# [Keycloak Admin Client]
KEYCLOAK_ADMIN_CLIENT_ID=truck-api
KEYCLOAK_ADMIN_CLIENT_SECRET=axJdFYxktpjc4JXLCxeuVusa
KEYCLOAK_ADMIN_GRANT_TYPE=client_credentials

# [Keycloak URLs]
KEYCLOAK_AUTHORIZATION_URL=http://localhost:8280/realms/truck/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=http://localhost:8280/realms/truck/protocol/openid-connect/token