generator client {
  provider     = "prisma-client"
  output       = "../src/prisma/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum PlatformRole {
  SYS_ADMIN
  PLATFORM_ADMIN
}

enum CompanyRole {
  COMPANY_ADMIN
  COMPANY_OPERATOR
  COMPANY_VIEWER
}

enum StoreRole {
  STORE_ADMIN
  STORE_OPERATOR
  STORE_VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD
  BLOCKED
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  DEFAULT
  SUSPENDED
  BLOCKED
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  DEFAULT
  SUSPENDED
  BLOCKED
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum MemberInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum AuditActorType {
  USER
  SYSTEM
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  phone     String     @unique
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  profile            UserProfile?
  companyMemberships CompanyMember[]
  storeMemberships   StoreMember[]
  companyInvitesSent CompanyMemberInvite[] @relation("CompanyInvitedBy")
  storeInvitesSent   StoreMemberInvite[]   @relation("StoreInvitedBy")
  listingsAsSeller   Listing[]             @relation("ListingCreator")

  auditLogsAsActor AuditLog[]
  favorites        Favorite[]
  ownedCompanies   Company[]     @relation("CompanyOwner")
  mediaUploads     MediaUpload[]

  @@map("users")
}

model UserProfile {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Company {
  id          String        @id @default(uuid())
  ownerId     String        @map("owner_id")
  planId      String        @map("plan_id")
  name        String
  email       String
  phone       String
  status      CompanyStatus @default(ACTIVE)
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  owner        User                  @relation("CompanyOwner", fields: [ownerId], references: [id])
  plan         Plan                  @relation(fields: [planId], references: [id])
  stores       Store[]
  invoices     Invoice[]             @relation("InvoiceCompany")
  members      CompanyMember[]
  storeMembers StoreMember[]
  listings     Listing[]
  leads        Lead[]
  invites      CompanyMemberInvite[]
  storeInvites StoreMemberInvite[]

  @@map("companies")
}

model Store {
  id           String      @id @default(uuid())
  companyId    String      @map("company_id")
  name         String
  slug         String      @unique
  email        String
  phone        String
  whatsapp     String
  logoUrl      String?     @map("logo_url")
  coverUrl     String?     @map("cover_url")
  brandColor   String?     @map("brand_color")
  description  String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String?     @default("BR")
  zipCode      String?     @map("zip_code")
  status       StoreStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  company  Company             @relation(fields: [companyId], references: [id])
  members  StoreMember[]
  invites  StoreMemberInvite[]
  listings Listing[]
  leads    Lead[]
  invoices Invoice[]           @relation("InvoiceStore")

  @@map("stores")
}

model Listing {
  id               String        @id @default(uuid())
  companyId        String        @map("company_id")
  storeId          String        @map("store_id")
  sellerId         String        @map("seller_id")
  classificationId String        @map("classification_id")
  categoryId       String        @map("category_id")
  brandId          String        @map("brand_id")
  modelId          String        @map("model_id")
  versionId        String        @map("version_id")
  title            String
  description      String?       @db.Text
  price            Float         @default(0)
  discount         Float         @default(0)
  status           ListingStatus @default(DRAFT)
  featured         Boolean       @default(false)
  publishedAt      DateTime?     @map("published_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  classification Classification @relation(fields: [classificationId], references: [id])
  category       Category       @relation(fields: [categoryId], references: [id])
  brand          Brand          @relation(fields: [brandId], references: [id])
  model          Model          @relation(fields: [modelId], references: [id])
  version        ModelVersion   @relation(fields: [versionId], references: [id])
  company        Company        @relation(fields: [companyId], references: [id])
  store          Store          @relation(fields: [storeId], references: [id])
  seller         User           @relation("ListingCreator", fields: [sellerId], references: [id])

  images          ListingImage[]

  attributes      ListingAttribute[]
  characteristics ListingCharacteristic[]
  leads           Lead[]
  favorites       Favorite[]

  @@index([classificationId])
  @@index([categoryId])
  @@index([companyId])
  @@index([storeId])
  @@index([brandId])
  @@index([modelId])
  @@index([sellerId])
  @@index([versionId])
  @@index([status])
  @@map("listings")
}

model Lead {
  id          String     @id @default(uuid())
  listingId   String     @map("listing_id")
  companyId   String     @map("company_id")
  storeId     String     @map("store_id")
  name        String
  email       String
  phone       String
  message     String     @db.Text
  status      LeadStatus @default(NEW)
  lgpdConsent Boolean    @default(false) @map("lgpd_consent")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  listing Listing @relation(fields: [listingId], references: [id])
  company Company @relation(fields: [companyId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  @@index([companyId])
  @@index([storeId])
  @@index([listingId])
  @@map("leads")
}

model Invoice {
  id         String        @id @default(uuid())
  externalId String        @unique @map("external_id")
  companyId  String        @map("company_id")
  storeId    String        @map("store_id")
  planId     String        @map("plan_id")
  amount     Float
  currency   String        @default("BRL")
  status     InvoiceStatus @default(PENDING)
  dueAt      DateTime      @map("due_at")
  paidAt     DateTime?     @map("paid_at")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")

  company Company @relation("InvoiceCompany", fields: [companyId], references: [id])
  store   Store   @relation("InvoiceStore", fields: [storeId], references: [id])
  plan    Plan    @relation(fields: [planId], references: [id])

  @@index([companyId])
  @@index([status])
  @@map("invoices")
}

model Plan {
  id          String   @id @default(uuid())
  name        String   @unique
  price       Float    @default(0)
  maxListings           Int     @default(1) @map("max_listings")
  maxStores             Int     @default(1) @map("max_stores")
  maxMembers            Int     @default(1) @map("max_members")
  maxFeatured           Int     @default(0) @map("max_featured")
  allowListingHighlight Boolean @default(false) @map("allow_listing_highlight")
  highlighted           Boolean @default(false)
  active                Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  companies       Company[]
  invoices        Invoice[]
  enabledFeatures PlanEnabledFeature[]
  highlights      PlanHighlight[]

  @@map("plans")
}

model PlanHighlight {
  id     String @id @default(uuid())
  planId String @map("plan_id")
  text   String
  order  Int    @default(0)

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
  @@map("plan_highlights")
}

model AuditLog {
  id         String         @id @default(uuid())
  action     String
  entityType String         @map("entity_type")
  entityId   String         @map("entity_id")
  actorType  AuditActorType @map("actor_type")
  actorId    String?        @map("actor_id")
  metadata   Json?
  createdAt  DateTime       @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Classification {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories Category[]
  listings   Listing[]

  @@map("classifications")
}

model Category {
  id               String  @id @default(uuid())
  classificationId String  @map("classification_id")
  name             String
  icon             String?
  order            Int     @default(0)

  classification  Classification  @relation(fields: [classificationId], references: [id])
  brandCategories BrandCategory[]
  modelCategories ModelCategory[]
  listings        Listing[]

  @@index([classificationId])
  @@map("categories")
}

model Brand {
  id    String  @id @default(uuid())
  name  String  @unique
  logo  String?
  order Int     @default(0)

  models          Model[]
  listings        Listing[]
  brandCategories BrandCategory[]

  @@map("brands")
}

model Model {
  id      String @id @default(uuid())
  brandId String @map("brand_id")
  name    String

  brand           Brand           @relation(fields: [brandId], references: [id])
  versions        ModelVersion[]
  listings        Listing[]
  modelCategories ModelCategory[]

  @@unique([brandId, name])
  @@map("models")
}

model ModelVersion {
  id      String @id @default(uuid())
  modelId String @map("model_id")
  name    String

  model    Model     @relation(fields: [modelId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([modelId, name])
  @@index([modelId])
  @@map("model_versions")
}

model Characteristic {
  id    String @id @default(uuid())
  name  String @unique
  order Int    @default(0)

  items    CharacteristicOption[]
  listings ListingCharacteristic[]

  @@map("characteristic_groups")
}

model CharacteristicOption {
  id               String @id @default(uuid())
  characteristicId String @map("characteristic_id")
  name             String
  order            Int    @default(0)

  characteristic Characteristic        @relation(fields: [characteristicId], references: [id], onDelete: Cascade)
  listings       ListingCharacteristic[]

  @@unique([characteristicId, name])
  @@index([characteristicId])
  @@map("characteristic_options")
}

model Attribute {
  id       String  @id @default(uuid())
  name     String  @unique
  required Boolean @default(false)
  order    Int     @default(0)

  options  AttributeOption[]
  listings ListingAttribute[]

  @@map("attribute_groups")
}

model AttributeOption {
  id          String @id @default(uuid())
  attributeId String @map("attribute_id")
  value       String
  order       Int    @default(0)

  attribute Attribute         @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  listings  ListingAttribute[]

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("attribute_options")
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  subtitle  String
  highlight String
  ctaText   String   @map("cta_text")
  ctaLink   String   @map("cta_link")
  imageUrl  String   @map("image_url")
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  features BannerFeature[]

  @@map("banners")
}

model BannerFeature {
  id       String @id @default(uuid())
  bannerId String @map("banner_id")
  text     String

  banner Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@index([bannerId])
  @@map("banner_features")
}

enum NewsletterSubscriptionStatus {
  PENDING
  SUBSCRIBED
  UNSUBSCRIBED
}

model NewsletterSubscription {
  id        String                       @id @default(uuid())
  email     String                       @unique
  status    NewsletterSubscriptionStatus @default(PENDING) @map("status")
  createdAt DateTime                     @default(now()) @map("created_at")
  updatedAt DateTime                     @updatedAt @map("updated_at")

  confirmations   NewsletterConfirmation[]
  unsubscriptions NewsletterUnsubscription[]

  @@map("newsletter_subscriptions")
}

model NewsletterConfirmation {
  id             String    @id @default(uuid())
  subscriptionId String    @map("subscription_id")
  token          String    @unique
  confirmedAt    DateTime? @map("confirmed_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("newsletter_confirmations")
}

model NewsletterUnsubscription {
  id             String    @id @default(uuid())
  subscriptionId String    @map("subscription_id")
  token          String    @unique
  confirmedAt    DateTime? @map("confirmed_at")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("newsletter_unsubscriptions")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}

model PlanFeature {
  key         PlanFeatureKey @id
  label       String
  description String?
  group       String

  enabledInPlans PlanEnabledFeature[]

  @@map("plan_features")
}

model CompanyMember {
  id        String      @id @default(uuid())
  companyId String      @map("company_id")
  userId    String      @map("user_id")
  role      CompanyRole
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@map("company_members")
}

model StoreMember {
  id        String    @id @default(uuid())
  companyId String    @map("company_id")
  storeId   String    @map("store_id")
  userId    String    @map("user_id")
  role      StoreRole
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([companyId])
  @@index([storeId])
  @@map("store_members")
}

model CompanyMemberInvite {
  id         String             @id @default(uuid())
  companyId  String             @map("company_id")
  senderId   String             @map("sender_id")
  email      String
  role       CompanyRole
  token      String             @unique
  status     MemberInviteStatus @default(PENDING)
  acceptedAt DateTime?          @map("accepted_at")
  declinedAt DateTime?          @map("declined_at")
  expiresAt  DateTime           @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sender  User    @relation("CompanyInvitedBy", fields: [senderId], references: [id])

  @@index([companyId])
  @@index([email])
  @@map("company_member_invites")
}

model StoreMemberInvite {
  id         String             @id @default(uuid())
  companyId  String             @map("company_id")
  storeId    String             @map("store_id")
  senderId   String             @map("sender_id")
  email      String
  role       StoreRole
  token      String             @unique
  status     MemberInviteStatus @default(PENDING)
  acceptedAt DateTime?          @map("accepted_at")
  declinedAt DateTime?          @map("declined_at")
  expiresAt  DateTime           @map("expires_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sender  User    @relation("StoreInvitedBy", fields: [senderId], references: [id])

  @@index([companyId])
  @@index([storeId])
  @@index([email])
  @@map("store_member_invites")
}

model BrandCategory {
  brandId    String @map("brand_id")
  categoryId String @map("category_id")

  brand    Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([brandId, categoryId])
  @@map("brand_categories")
}

model ModelCategory {
  modelId    String @map("model_id")
  categoryId String @map("category_id")

  model    Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([modelId, categoryId])
  @@map("model_categories")
}

model ListingImage {
  id        String           @id @default(uuid())
  listingId String           @map("listing_id")
  url       String
  slot      ListingImageSlot
  order     Int              @default(0)

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, slot])
  @@index([listingId])
  @@map("listing_images")
}

model ListingAttribute {
  listingId         String @map("listing_id")
  attributeId       String @map("attribute_id")
  attributeOptionId String @map("attribute_option_id")

  listing         Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  attribute       Attribute       @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  attributeOption AttributeOption @relation(fields: [attributeOptionId], references: [id], onDelete: Cascade)

  @@id([listingId, attributeOptionId])
  @@index([listingId, attributeId])
  @@map("listing_attributes")
}

model ListingCharacteristic {
  listingId              String @map("listing_id")
  characteristicId       String @map("characteristic_id")
  characteristicOptionId String @map("characteristic_option_id")

  listing              Listing              @relation(fields: [listingId], references: [id], onDelete: Cascade)
  characteristic       Characteristic       @relation(fields: [characteristicId], references: [id], onDelete: Cascade)
  characteristicOption CharacteristicOption @relation(fields: [characteristicOptionId], references: [id], onDelete: Cascade)

  @@id([listingId, characteristicOptionId])
  @@index([listingId, characteristicId])
  @@map("listing_characteristics")
}

model PlanEnabledFeature {
  planId     String         @map("plan_id")
  featureKey PlanFeatureKey @map("feature_key")

  plan    Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature PlanFeature @relation(fields: [featureKey], references: [key], onDelete: Cascade)

  @@id([planId, featureKey])
  @@map("plan_enabled_features")
}

enum PlanFeatureKey {
  LISTINGS_CREATE
  LISTINGS_EDIT_OWN
  LISTINGS_EDIT_STORE
  LISTINGS_DELETE
  LISTINGS_VIEW_ALL

  LEADS_VIEW_OWN
  LEADS_VIEW_STORE
  LEADS_MANAGE_STATUS

  STORES_EDIT
  STORES_VIEW
  STORES_MULTI
  STORES_SHOWROOM

  TEAM_MANAGE_SELLERS
  TEAM_MANAGE_MANAGERS
  TEAM_MULTI_STORE

  FINANCE_VIEW_INVOICES
  FINANCE_MANAGE_PLAN
  FINANCE_EDIT_COMPANY

  DASHBOARD_BASIC
  DASHBOARD_ADVANCED
  DASHBOARD_STORE_METRICS
  DASHBOARD_COMPANY_METRICS

  OTHER_EDIT_PROFILE
  OTHER_FAVORITES
  OTHER_CONTACT_FORM
  OTHER_SHARE_LISTINGS
  OTHER_PRIORITY_SUPPORT
  OTHER_DEDICATED_SUPPORT
}

enum ListingImageSlot {
  FRONT
  FRONT_LEFT
  FRONT_RIGHT
  SIDE_LEFT
  SIDE_RIGHT
  REAR
  REAR_LEFT
  REAR_RIGHT
  INTERIOR
}

enum MediaUploadStatus {
  PENDING
  CONFIRMED
  ORPHANED
}

model MediaUpload {
  id          String            @id @default(uuid())
  uploaderId  String            @map("uploader_id")
  key         String            @unique
  url         String
  mimeType    String            @map("mime_type")
  size        Int               @map("size")
  status      MediaUploadStatus @default(PENDING)
  entityType  String            @map("entity_type")
  entityId    String            @map("entity_id")
  confirmedAt DateTime?         @map("confirmed_at")
  expiresAt   DateTime          @map("expires_at")
  createdAt   DateTime          @default(now()) @map("created_at")

  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([uploaderId])
  @@index([status])
  @@index([entityType, entityId])
  @@map("media_uploads")
}
